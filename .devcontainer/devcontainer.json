{
  "name": "LambadaClips",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "postCreateCommand": "echo 'Ready! Run: docker compose up -d'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "forwardPorts": [5173, 8000, 3000, 8080]
}
